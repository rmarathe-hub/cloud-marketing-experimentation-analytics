# AWS
AWS_PROFILE=marketing-analytics
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_RAW_PREFIX=raw
S3_PROCESSED_PREFIX=processed
S3_MARTS_PREFIX=marts
S3_EXPORT_PREFIX=exports

# DuckDB
DUCKDB_PATH=data/processed/marketing_analytics.duckdb

# Optional: Kaggle API for full Avazu train.gz
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Optional: local Avazu source or sample size
# AVAZU_SOURCE_PATH=/path/to/train.gz
AVAZU_SAMPLE_ROWS=500000